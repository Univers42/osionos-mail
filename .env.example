# -----------------------------------------------------------------------------
# osionos Mail and Gmail bridge runtime
# Managed by apps/baas/scripts/vault-env.mjs.
# Copy to the matching .env file only for local development; Vault is the source of truth after seeding.
# -----------------------------------------------------------------------------

# REQUIRED: Required. The service will not boot, authenticate, or bridge correctly without these keys.
# Required. Google OAuth client ID used by Mail and Calendar bridges. If omitted: startup, auth, or bridge flow can fail.
GOOGLE_CLIENT_ID=

# Required. Google OAuth client secret used by Mail and Calendar bridges. If omitted: startup, auth, or bridge flow can fail.
GOOGLE_CLIENT_SECRET=

# RECOMMENDED: Recommended. Defaults keep local Docker usable, but set these to make routing, email, and integrations explicit.
# Recommended. Runtime configuration key for this service. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
GMAIL_DETAIL_BATCH_SIZE=20

# Recommended. Runtime configuration key for this service. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
GMAIL_LIST_PAGE_SIZE=500

# Recommended. Runtime configuration key for this service. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
GMAIL_MAX_SYNC_LIMIT=5000

# Recommended. Service URL used for local routing. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
GMAIL_REDIRECT_URI=http://localhost:4100/auth/gmail/callback

# Recommended. Runtime configuration key for this service. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
GMAIL_SYNC_LIMIT=2000

# Recommended. Runtime configuration key for this service. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MAIL_APP_ORIGIN=http://localhost:3002

# Recommended. Local port for Docker or development tooling. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MAIL_BRIDGE_PORT=4100

# Recommended. Runtime configuration key for this service. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
MAIL_BRIDGE_PUBLIC_ORIGIN=http://localhost:4100

# Recommended. Browser-exposed configuration. Never put private secrets in this key. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
VITE_GMAIL_SYNC_LIMIT=2000

# Recommended. Browser-exposed configuration. Never put private secrets in this key. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
VITE_GMAIL_SYNC_PAGE_SIZE=100

# OPTIONAL: Optional. Leave empty to disable the integration and gain a smaller local attack surface.
# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
GMAIL_CALLBACK_PATHS=

# Optional. Enable Mail bridge OAuth credential loading from Vault. If omitted: the related integration is disabled, reducing local secret sprawl.
MAIL_BRIDGE_VAULT_ENABLED=false

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
MAIL_BRIDGE_VAULT_OAUTH_PATH=secret/data/mini-baas/oauth

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
VAULT_ADDR=http://vault:8200

# Optional. Vault AppRole role ID for services or invited collaborators. If omitted: the related integration is disabled, reducing local secret sprawl.
VAULT_ROLE_ID=

# Optional. Vault AppRole secret ID for services or invited collaborators. If omitted: the related integration is disabled, reducing local secret sprawl.
VAULT_SECRET_ID=

# Optional. Short-lived Vault token for fetching or publishing managed environment data. If omitted: the related integration is disabled, reducing local secret sprawl.
VAULT_TOKEN=
